<!doctype html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#E86A5A" />
  <meta name="description" content="{{ description or site.description or site.subtitle }}" />
  <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
  <link rel="icon" href="{{ '/assets/avatar.png' | url }}" />
  <link rel="stylesheet" href="{{ '/assets/fonts/lxgw-wenkai-subset.css' | url }}" />
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}" />
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <div class="bar">
        <a class="brand" href="{{ '/' | url }}">
          <img class="avatar" src="{{ '/assets/avatar.png' | url }}" alt="" />
          <span class="title">
            <strong>{{ site.title }}</strong>
            <span>{{ site.subtitle }}</span>
          </span>
        </a>
        <nav class="nav" aria-label="site">
          <a href="{{ '/archive/' | url }}">归档</a>
        </nav>
      </div>
    </div>
  </header>

  <main class="wrap">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="bar">
        <p>© {{ build.year }} 滚雪球的Star · <span class="muted">Star</span> · <span class="muted">今天也庆祝一下</span></p>
        <a class="beian-link" href="https://beian.miit.gov.cn" target="_blank" rel="noopener noreferrer">浙ICP备17053536号-2</a>
      </div>
    </div>
  </footer>
  <script type="module">
    const diagrams = document.querySelectorAll("pre.mermaid");
    if (diagrams.length > 0) {
      const { default: mermaid } = await import(
        "https://cdn.jsdelivr.net/npm/mermaid@11.16.0/dist/mermaid.esm.min.mjs"
      );
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "strict",
        theme: "neutral",
        flowchart: {
          htmlLabels: true,
          useMaxWidth: true,
          nodeSpacing: 20,
          rankSpacing: 30
        }
      });
      await mermaid.run({ nodes: diagrams });
    }
  </script>
</body>
</html>
