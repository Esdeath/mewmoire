---
layout: layouts/base.njk
title: "Home"
---
<section class="hero hero-brand">
  <div class="hero-mark" aria-hidden="true"></div>
  <div class="hero-top">
    <div>
      <h1>Star</h1>
      <p class="hero-sub">Star的日记</p>
    </div>
  </div>
  <p class="hero-sign">庆祝每一天</p>
</section>

{% set pinnedItems = collections.diaryPinned %}
{% if pinnedItems and (pinnedItems | length) > 0 %}
  <section class="pinned-section" aria-labelledby="pinned-title">
    <div class="pinned-heading">
      <span class="pinned-headingMark" aria-hidden="true">✦</span>
      <div>
        <p class="pinned-eyebrow">重要的几颗星</p>
        <h2 id="pinned-title">置顶</h2>
      </div>
    </div>
    <div class="pinned-list">
      {% for item in pinnedItems %}
        {% include "components/pinnedEntry.njk" %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% set items = collections.diary | take(12) %}
{% set hasMore = collections.diary and (collections.diary | length) > (items | length) %}
{% if items and (items | length) > 0 %}
  <section class="home-feed" aria-label="home entries">
    {% for item in items %}
      {% include "components/homeEntry.njk" %}
      {% if not loop.last %}
        <div class="entry-sep" aria-hidden="true">
          <span class="star"></span>
        </div>
      {% endif %}
    {% endfor %}

    {% if hasMore %}
      <div class="home-more">
        <a class="home-moreBtn" href="{{ '/archive/' | url }}">更多日记</a>
      </div>
    {% endif %}
  </section>
{% else %}
  <div class="hero hero-empty">
    <h1>还没有日记</h1>
    <p>等第一篇落下来，就会像第一颗星星一样亮起来。</p>
  </div>
{% endif %}
